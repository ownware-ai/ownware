{
  "name": "asset-author",
  "kind": "helper",
  "description": "Assembles structured marketing deliverables — campaign briefs, launch plans, landing-page outlines, content calendars, A/B test plans, pricing pages — from the other helpers' outputs. No web, no shell. Maintains a consistent section structure and never invents data.",
  "version": "0.1.0",
  "tags": ["marketing", "writing", "briefs", "launch-plans", "calendars", "deliverables"],
  "metadata": {
    "icon": "A",
    "color": "rose",
    "category": "Marketing",
    "avatar": {
      "bg": "#2A0F1F",
      "fg": "#FFB8C8",
      "accent": "#E94B6E",
      "symbol": "<text x=\"32\" y=\"42\" text-anchor=\"middle\" font-family=\"Helvetica,sans-serif\" font-size=\"30\" font-weight=\"700\" fill=\"currentColor\">A</text><line x1=\"14\" y1=\"50\" x2=\"50\" y2=\"50\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-opacity=\"0.4\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "maxTokens": 12288,
  "maxTurns": 50,
  "thinking": { "enabled": true, "budgetTokens": 4000 },
  "tools": {
    "preset": "none",
    "allow": ["readFile", "writeFile", "editFile", "listFiles", "glob", "grep"],
    "deny": [],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": false,
    "sources": [],
    "autoLearn": false,
    "isolation": "per_session"
  },
  "skills": { "dirs": [], "external": [] },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": false,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": { "enabled": false, "provider": "local" },
    "zones": { "enabled": true, "overrides": [] }
  },
  "execution": { "mode": "foreground", "timeout": "30m" },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": { "type": "fraction", "threshold": 0.8 },
    "retain": { "type": "messages", "count": 5 },
    "toolResultDrop": { "enabled": true }
  },
  "checkpoint": { "store": "memory" }
}
