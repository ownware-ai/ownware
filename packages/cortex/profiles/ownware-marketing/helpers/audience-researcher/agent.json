{
  "name": "audience-researcher",
  "kind": "helper",
  "description": "Mines voice-of-customer from public reviews (G2, Capterra, App Store, Trustpilot, Reddit, X), the user's own support tickets, and interview transcripts. Returns sourced quotes, recurring pain points, and the language customers actually use. Read-only.",
  "version": "0.1.0",
  "tags": ["marketing", "research", "voc", "audience", "personas"],
  "metadata": {
    "icon": "R",
    "color": "rose",
    "category": "Marketing",
    "avatar": {
      "bg": "#2A0F1F",
      "fg": "#FFB8C8",
      "accent": "#E94B6E",
      "symbol": "<text x=\"32\" y=\"42\" text-anchor=\"middle\" font-family=\"Helvetica,sans-serif\" font-size=\"30\" font-weight=\"700\" fill=\"currentColor\">R</text><line x1=\"14\" y1=\"50\" x2=\"50\" y2=\"50\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-opacity=\"0.4\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "maxTokens": 10240,
  "maxTurns": 35,
  "tools": {
    "preset": "readonly",
    "allow": ["web_fetch", "web_search"],
    "deny": [],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": false,
    "sources": [],
    "autoLearn": false,
    "isolation": "per_session"
  },
  "skills": { "dirs": [], "external": [] },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": false,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "strict",
    "permissionMode": "ask",
    "sandbox": { "enabled": false, "provider": "local" },
    "zones": { "enabled": true, "overrides": [] }
  },
  "execution": { "mode": "foreground", "timeout": "20m" },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": { "type": "fraction", "threshold": 0.8 },
    "retain": { "type": "messages", "count": 5 },
    "toolResultDrop": { "enabled": true }
  },
  "checkpoint": { "store": "memory" }
}
