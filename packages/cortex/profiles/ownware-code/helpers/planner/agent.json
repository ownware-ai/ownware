{
  "name": "planner",
  "kind": "helper",
  "description": "Software architect. Explores the codebase read-only and returns a step-by-step implementation plan with critical files and trade-offs.",
  "version": "0.1.0",
  "tags": [
    "helper",
    "coding",
    "architecture",
    "read-only"
  ],
  "metadata": {
    "icon": "route",
    "color": "violet",
    "category": "Engineering Helpers",
    "avatar": {
      "bg": "#1E1A3E",
      "fg": "#C9BEFC",
      "accent": "#7C5CFC",
      "symbol": "<circle cx=\"16\" cy=\"16\" r=\"4\" fill=\"currentColor\"/><circle cx=\"48\" cy=\"48\" r=\"4\" fill=\"currentColor\"/><path d=\"M16 20 C 16 32, 32 32, 32 44 C 32 52, 44 52, 48 48\" stroke=\"currentColor\" stroke-width=\"2.4\" fill=\"none\" stroke-linecap=\"round\"/>"
    }
  },
  "model": "openrouter:kimi-k2.6",
  "smallFastModel": "openai:gpt-5-nano",
  "maxTokens": 16384,
  "maxTurns": 30,
  "tools": {
    "preset": "full",
    "allow": [],
    "deny": [
      "writeFile",
      "editFile",
      "shell_execute",
      "agent_spawn",
      "browser_*",
      "memory_*",
      "image_generate",
      "speech_synthesize",
      "speech_transcribe",
      "ask_user"
    ],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": true,
    "sources": [
      "AGENTS.md"
    ],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": [
      "skills/"
    ],
    "external": []
  },
  "context": {
    "git": true,
    "os": false,
    "cwd": true,
    "datetime": false,
    "project": true,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": {
      "enabled": false,
      "provider": "local"
    },
    "zones": {
      "enabled": false,
      "overrides": []
    }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "20m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": {
      "type": "fraction",
      "threshold": 0.8
    },
    "retain": {
      "type": "messages",
      "count": 6
    },
    "toolResultDrop": {
      "enabled": true
    }
  },
  "checkpoint": {
    "store": "file"
  }
}
