{
  "name": "ownware-backend",
  "kind": "agent",
  "description": "Ownware Backend — APIs, databases, infrastructure, migrations, background jobs. Terminal-heavy. Reads the codebase, writes the server, runs the database, instruments observability. The Coder for everything below the UI.",
  "version": "0.1.0",
  "productId": "ownware-coder",
  "locked": true,
  "tags": [
    "backend",
    "api",
    "database",
    "infrastructure",
    "shell"
  ],
  "metadata": {
    "icon": "B",
    "color": "slate",
    "category": "Engineering",
    "avatar": {
      "bg": "#3A2E14",
      "fg": "#F8E0A8",
      "accent": "#F59E0B",
      "symbol": "<rect x=\"16\" y=\"18\" width=\"32\" height=\"8\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><rect x=\"16\" y=\"30\" width=\"32\" height=\"8\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><rect x=\"16\" y=\"42\" width=\"32\" height=\"8\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><circle cx=\"22\" cy=\"22\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"22\" cy=\"34\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"22\" cy=\"46\" r=\"1.5\" fill=\"currentColor\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "smallFastModel": "anthropic:claude-haiku-4-5",
  "maxTokens": 16384,
  "maxTurns": 100,
  "thinking": {
    "enabled": true,
    "budgetTokens": 8000
  },
  "tools": {
    "preset": "full",
    "allow": [],
    "deny": [
      "browser_*",
      "image_generate",
      "speech_synthesize",
      "speech_transcribe"
    ],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": true,
    "sources": [
      "AGENTS.md"
    ],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": [
      "skills/"
    ],
    "external": []
  },
  "context": {
    "git": true,
    "os": true,
    "cwd": true,
    "datetime": true,
    "project": true,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": {
      "enabled": false,
      "provider": "local"
    },
    "zones": {
      "enabled": true,
      "overrides": []
    }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "60m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": {
      "type": "fraction",
      "threshold": 0.8
    },
    "retain": {
      "type": "messages",
      "count": 6
    },
    "toolResultDrop": {
      "enabled": true
    }
  },
  "checkpoint": {
    "store": "file"
  },
  "panes": {
    "allowedKinds": [
      "chat", "markdown", "code", "diff", "terminal", "files", "json", "csv", "tasks", "plan", "txt"
    ],
    "defaultAgentPlacement": "split",
    "newTabPresets": []
  }
}
