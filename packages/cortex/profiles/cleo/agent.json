{
  "name": "cleo",
  "kind": "agent",
  "description": "Front-line customer support that's fast, accurate, on-brand, and knows when to escalate. Watches the support queue, answers from your help docs, auto-resolves the high-confidence routine, drafts the tricky ones, tags and routes tickets, spots recurring issues, and hands the hard or sensitive ones to you with the customer's full history and a suggested reply. Grounds every answer in the docs — never guesses — and escalates anything billing, outage, account, or legal.",
  "version": "0.1.0",
  "productId": "ownware",
  "locked": false,
  "tags": [
    "customer-support",
    "support",
    "helpdesk",
    "ticketing",
    "triage",
    "escalation",
    "intercom",
    "zendesk",
    "csat"
  ],
  "metadata": {
    "icon": "C",
    "color": "teal",
    "category": "Support",
    "role": "Customer support",
    "avatar": {
      "bg": "#04221E",
      "fg": "#99F6E4",
      "accent": "#2DD4BF",
      "symbol": "<path d=\"M16 18 h32 a4 4 0 0 1 4 4 v17 a4 4 0 0 1 -4 4 h-17 l-10 8 v-8 h-5 a4 4 0 0 1 -4 -4 v-17 a4 4 0 0 1 4 -4 z\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linejoin=\"round\"/><polyline points=\"24,30 30,36 41,24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>"
    },
    "requiredSecrets": []
  },
  "model": "anthropic:claude-sonnet-4-6",
  "smallFastModel": "anthropic:claude-haiku-4-5",
  "maxTokens": 16384,
  "maxTurns": 120,
  "thinking": {
    "enabled": true,
    "budgetTokens": 8000
  },
  "tools": {
    "preset": "full",
    "allow": [],
    "deny": ["shell_execute", "agent_spawn"],
    "custom": [],
    "mcp": {},
    "composio": {
      "toolkits": ["intercom", "zendesk", "gmail", "slack"]
    }
  },
  "memory": {
    "enabled": true,
    "sources": ["AGENTS.md"],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": ["skills/"],
    "external": []
  },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": false,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": { "enabled": false, "provider": "local" },
    "zones": { "enabled": true, "overrides": [] }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "60m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": { "type": "fraction", "threshold": 0.8 },
    "retain": { "type": "messages", "count": 6 },
    "toolResultDrop": { "enabled": true }
  },
  "checkpoint": { "store": "file" },
  "cache": { "ttl": "1h" },
  "panes": {
    "allowedKinds": [
      "chat", "markdown", "tasks", "files", "url", "csv", "pdf"
    ],
    "defaultAgentPlacement": "split",
    "newTabPresets": []
  }
}
