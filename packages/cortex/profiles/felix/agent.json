{
  "name": "felix",
  "displayName": "Felix",
  "kind": "agent",
  "description": "Finance & billing-ops operator. Keeps money moving in and out, clean and on time. Reconciles Stripe activity against the ledger, flags failed and at-risk charges, drafts dunning, chases overdue invoices, generates invoices and reports, and watches for anomalies like refund spikes or churn signals. Reads, drafts, and notifies — never moves real money. Every charge, refund, or payout is staged for the operator's explicit approval.",
  "version": "0.1.0",
  "productId": "ownware",
  "locked": false,
  "tags": [
    "finance",
    "billing",
    "payments",
    "reconciliation",
    "dunning",
    "invoicing",
    "accounts-receivable",
    "stripe",
    "bookkeeping"
  ],
  "metadata": {
    "icon": "F",
    "color": "rose",
    "category": "Finance",
    "role": "Finance & billing ops",
    "avatar": {
      "bg": "#2A0D17",
      "fg": "#FECDD3",
      "accent": "#FB7185",
      "symbol": "<circle cx=\"32\" cy=\"32\" r=\"17\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\"/><line x1=\"23\" y1=\"28\" x2=\"41\" y2=\"28\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\"/><line x1=\"23\" y1=\"36\" x2=\"41\" y2=\"36\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>"
    },
    "requiredSecrets": []
  },
  "model": "anthropic:claude-sonnet-4-6",
  "smallFastModel": "anthropic:claude-haiku-4-5",
  "maxTokens": 16384,
  "maxTurns": 120,
  "thinking": {
    "enabled": true,
    "budgetTokens": 8000
  },
  "tools": {
    "preset": "full",
    "allow": [],
    "deny": ["shell_execute", "agent_spawn"],
    "custom": [],
    "mcp": {},
    "composio": {
      "toolkits": ["stripe", "quickbooks", "xero", "gmail", "slack"]
    }
  },
  "memory": {
    "enabled": true,
    "sources": ["AGENTS.md"],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": ["skills/"],
    "external": []
  },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": false,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": { "enabled": false, "provider": "local" },
    "zones": { "enabled": true, "overrides": [] }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "60m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": { "type": "fraction", "threshold": 0.8 },
    "retain": { "type": "messages", "count": 6 },
    "toolResultDrop": { "enabled": true }
  },
  "checkpoint": { "store": "file" },
  "cache": { "ttl": "1h" },
  "panes": {
    "allowedKinds": [
      "chat", "markdown", "csv", "files", "tasks", "url", "pdf"
    ],
    "defaultAgentPlacement": "split",
    "newTabPresets": []
  }
}
