{
  "name": "ownware-architect",
  "kind": "agent",
  "description": "Ownware Architect — system design, schemas, ADRs, technical decisions. Reads the codebase, writes architecture documents, proposes structures. Edits sparingly; the architect documents and reviews, the coder implements.",
  "version": "0.1.0",
  "productId": "ownware-coder",
  "locked": true,
  "tags": [
    "architecture",
    "design",
    "decisions",
    "documentation"
  ],
  "metadata": {
    "icon": "A",
    "color": "slate",
    "category": "Engineering",
    "avatar": {
      "bg": "#3A2E14",
      "fg": "#F8E0A8",
      "accent": "#F59E0B",
      "symbol": "<path d=\"M16 50 L32 14 L48 50\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/><line x1=\"22\" y1=\"38\" x2=\"42\" y2=\"38\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "smallFastModel": "anthropic:claude-haiku-4-5",
  "maxTokens": 16384,
  "maxTurns": 80,
  "thinking": {
    "enabled": true,
    "budgetTokens": 8000
  },
  "tools": {
    "preset": "coding",
    "allow": [
      "readFile",
      "editFile",
      "writeFile",
      "grep",
      "glob",
      "ls",
      "shell"
    ],
    "deny": [
      "browser_*",
      "image_generate",
      "speech_synthesize",
      "speech_transcribe"
    ],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": true,
    "sources": [
      "AGENTS.md"
    ],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": [
      "skills/"
    ],
    "external": []
  },
  "context": {
    "git": true,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": true,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": {
      "enabled": false,
      "provider": "local"
    },
    "zones": {
      "enabled": true,
      "overrides": []
    }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "60m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": {
      "type": "fraction",
      "threshold": 0.8
    },
    "retain": {
      "type": "messages",
      "count": 6
    },
    "toolResultDrop": {
      "enabled": true
    }
  },
  "checkpoint": {
    "store": "file"
  },
  "panes": {
    "allowedKinds": [
      "chat", "markdown", "code", "mermaid", "diff", "files", "plan", "json", "txt"
    ],
    "defaultAgentPlacement": "split",
    "newTabPresets": []
  }
}
