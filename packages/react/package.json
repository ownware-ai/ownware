{
  "name": "@ownware/react",
  "version": "0.1.1",
  "description": "Ownware chat kit for React — useOwnwareAgent() drives a live agent (run + stream + resume) through the headless @ownware/ui reducer. Headless now; <OwnwareChat> component next.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ownware/client": "workspace:*",
    "@ownware/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "author": "Ownware Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ownware-ai/ownware.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/ownware-ai/ownware#readme",
  "bugs": {
    "url": "https://github.com/ownware-ai/ownware/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "chat",
    "react",
    "hook",
    "ownware"
  ]
}
