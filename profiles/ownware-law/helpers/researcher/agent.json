{
  "name": "legal-researcher",
  "kind": "helper",
  "description": "Legal research specialist. Finds case law, statutes, regulations, and precedent. Fast, read-only, exhaustive. Runs on Haiku for speed.",
  "version": "0.1.0",
  "tags": [
    "helper",
    "legal",
    "research",
    "read-only"
  ],
  "metadata": {
    "icon": "library-big",
    "color": "violet",
    "category": "Legal Helpers",
    "avatar": {
      "bg": "#1E1A3E",
      "fg": "#C9BEFC",
      "accent": "#7C5CFC",
      "symbol": "<rect x=\"14\" y=\"16\" width=\"6\" height=\"32\" rx=\"1.5\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><rect x=\"22\" y=\"16\" width=\"6\" height=\"32\" rx=\"1.5\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><rect x=\"30\" y=\"16\" width=\"6\" height=\"32\" rx=\"1.5\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\"/><path d=\"M40 18 L50 20 L44 50 L38 48 Z\" stroke=\"currentColor\" stroke-width=\"2.2\" fill=\"none\" stroke-linejoin=\"round\"/>"
    }
  },
  "model": "anthropic:claude-haiku-4-5-20251001",
  "maxTokens": 16384,
  "maxTurns": 25,
  "tools": {
    "preset": "full",
    "allow": [],
    "deny": [
      "writeFile",
      "editFile",
      "shell_execute",
      "agent_spawn",
      "image_*",
      "speech_*",
      "memory_*"
    ],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": true,
    "sources": [
      "AGENTS.md"
    ],
    "autoLearn": true,
    "isolation": "shared"
  },
  "skills": {
    "dirs": [
      "skills/"
    ],
    "external": []
  },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": true,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": {
      "enabled": false,
      "provider": "local"
    },
    "zones": {
      "enabled": false,
      "overrides": []
    }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "15m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": {
      "type": "fraction",
      "threshold": 0.8
    },
    "retain": {
      "type": "messages",
      "count": 6
    }
  },
  "checkpoint": {
    "store": "file"
  }
}
