{
  "name": "deck-author",
  "kind": "helper",
  "description": "Drafts structured deliverables — pitchbooks, CIMs, IC memos, one-pagers, client review packs, financial plans. No web, no shell. Takes inputs from the other helpers and assembles them into the firm's section/page conventions.",
  "version": "0.1.0",
  "tags": ["finance", "writing", "decks", "memos", "cim", "pitchbook"],
  "metadata": {
    "icon": "A",
    "color": "teal",
    "category": "Finance",
    "avatar": {
      "bg": "#0F2A2E",
      "fg": "#A8E6D4",
      "accent": "#00D4AA",
      "symbol": "<text x=\"32\" y=\"42\" text-anchor=\"middle\" font-family=\"Georgia,serif\" font-size=\"30\" font-weight=\"600\" fill=\"currentColor\">A</text><line x1=\"14\" y1=\"50\" x2=\"50\" y2=\"50\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-opacity=\"0.4\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "maxTokens": 12288,
  "maxTurns": 50,
  "thinking": { "enabled": true, "budgetTokens": 4000 },
  "tools": {
    "preset": "none",
    "allow": ["readFile", "writeFile", "editFile", "listFiles", "glob", "grep"],
    "deny": [],
    "custom": [],
    "mcp": {}
  },
  "memory": {
    "enabled": false,
    "sources": [],
    "autoLearn": false,
    "isolation": "per_session"
  },
  "skills": { "dirs": [], "external": [] },
  "context": {
    "git": false,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": false,
    "modelInfo": false,
    "contextUsage": false
  },
  "security": {
    "level": "standard",
    "permissionMode": "ask",
    "sandbox": { "enabled": false, "provider": "local" },
    "zones": { "enabled": true, "overrides": [] }
  },
  "execution": { "mode": "foreground", "timeout": "30m" },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": { "type": "fraction", "threshold": 0.8 },
    "retain": { "type": "messages", "count": 5 },
    "toolResultDrop": { "enabled": true }
  },
  "checkpoint": { "store": "memory" }
}
