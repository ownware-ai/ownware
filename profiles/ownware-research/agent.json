{
  "name": "ownware-research",
  "description": "Read-only research agent — searches, reads, analyzes. Never modifies files.",
  "version": "0.1.0",
  "tags": [
    "research",
    "read-only",
    "analysis"
  ],
  "metadata": {
    "icon": "R",
    "color": "teal",
    "category": "Research",
    "avatar": {
      "bg": "#7A2E12",
      "fg": "#F8CCB6",
      "accent": "#D85A30",
      "symbol": "<circle cx=\"27\" cy=\"27\" r=\"12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"/><line x1=\"36\" y1=\"36\" x2=\"48\" y2=\"48\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"/><circle cx=\"27\" cy=\"27\" r=\"4\" fill=\"currentColor\" fill-opacity=\"0.3\"/>"
    }
  },
  "model": "anthropic:claude-sonnet-4-6",
  "smallFastModel": "anthropic:claude-haiku-4-5",
  "maxTurns": 50,
  "maxTokens": 16384,
  "tools": {
    "preset": "readonly",
    "allow": [],
    "deny": [
      "shell_execute"
    ],
    "custom": [],
    "mcp": {}
  },
  "context": {
    "git": true,
    "os": false,
    "cwd": true,
    "datetime": true,
    "project": true,
    "modelInfo": false,
    "contextUsage": false
  },
  "memory": {
    "enabled": true,
    "sources": [
      "AGENTS.md"
    ],
    "autoLearn": false,
    "isolation": "shared"
  },
  "skills": {
    "dirs": [],
    "external": []
  },
  "security": {
    "level": "strict",
    "permissionMode": "ask",
    "sandbox": {
      "enabled": false,
      "provider": "local"
    }
  },
  "execution": {
    "mode": "foreground",
    "timeout": "30m"
  },
  "subagents": [],
  "compaction": {
    "strategy": "summarize",
    "trigger": {
      "type": "fraction",
      "threshold": 0.8
    },
    "retain": {
      "type": "messages",
      "count": 6
    },
    "toolResultDrop": {
      "enabled": true
    }
  },
  "checkpoint": {
    "store": "memory"
  }
}
