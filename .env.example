# Ownware — example environment.
# Copy to `.env` (git-ignored) and fill in what you use. Everything here is OPTIONAL:
# the zero-config default is a safe, keyless, loopback gateway. Prefer `ownware key add`
# (encrypted vault) over env vars for provider keys in real deployments.

# ── Model providers (set the ones you use; Ollama needs no key) ──────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
# Non-default Ollama server (keyless local models):
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Gateway (only if you're not passing GatewayOptions / serve flags) ────────
# OWNWARE_DATA_DIR=~/.ownware        # where state lives (default ~/.ownware)
# OWNWARE_HOST=127.0.0.1             # non-loopback forces auth + TLS
# OWNWARE_PORT=3011                  # gateway port
# OWNWARE_GATEWAY_TLS=0              # 0 = plain HTTP (loopback only)
# OWNWARE_MASTER_KEY=               # hex 32-byte vault key (set in containers/CI)

# ── Connectors / tools (optional) ────────────────────────────────────────────
# COMPOSIO_API_KEY=                 # enables 400+ SaaS toolkits via Composio

# See docs/reference/configuration.md for the full list of variables.
